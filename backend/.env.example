FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
# Use SQLite for development:
DATABASE_URL=sqlite:///instance/stock.db
